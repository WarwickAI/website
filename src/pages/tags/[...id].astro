---
import ContentCard from '@/components/ContentCard.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllTags, getEntriesByTag } from '@/lib/data-utils'
import { allConfigs } from '@/lib/collections'

export async function getStaticPaths() {
  const tagSets = await Promise.all(
    allConfigs.map((config) => getAllTags(config)),
  )
  const uniqueTags = new Set<string>()
  for (const tagMap of tagSets) {
    for (const tag of tagMap.keys()) uniqueTags.add(tag)
  }

  return Promise.all(
    [...uniqueTags].map(async (tag) => {
      const matches = (
        await Promise.all(
          allConfigs.map(async (config) => {
            const entries = await getEntriesByTag(config, tag)
            return entries.map((entry) => ({ entry, config }))
          }),
        )
      )
        .flat()
        .sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf())

      return {
        params: { id: tag },
        props: { tag, matches },
      }
    }),
  )
}

const { tag, matches } = Astro.props
---

<Layout class="max-w-3xl">
  <PageHead
    slot="head"
    title={`Posts tagged with "${tag}"`}
    description={`A collection of posts tagged with ${tag}.`}
    noindex
  />
  <Breadcrumbs
    items={[
      { href: '/tags', label: 'Tags', icon: 'lucide:tags' },
      { label: tag, icon: 'lucide:tag' },
    ]}
  />

  <ul class="flex flex-col gap-y-4">
    {
      matches.map(({ entry, config }) => (
        <li>
          <ContentCard entry={entry} config={config} />
        </li>
      ))
    }
  </ul>
</Layout>
