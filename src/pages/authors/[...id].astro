---
import AuthorCard from '@/components/AuthorCard.astro'
import ContentCard from '@/components/ContentCard.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
import {
  getAllAuthors,
  getEntriesByAuthor,
  getRolesForAuthor,
} from '@/lib/data-utils'
import { allConfigs } from '@/lib/collections'

export async function getStaticPaths() {
  const authors = await getAllAuthors()
  return authors.map((author) => ({
    params: { id: author.id },
    props: { author },
  }))
}

const { author } = Astro.props

const roles = await getRolesForAuthor(author.id)
const isExec = roles.length > 0
const badges = roles.map((r) => ({
  text: `${r.role} · ${r.year}`,
  current: r.isCurrent,
  href: r.isCurrent ? '/authors/exec' : `/authors/exec/${r.year}`,
}))

const authorEntries = (
  await Promise.all(
    allConfigs.map(async (config) => {
      const entries = await getEntriesByAuthor(config, author.id)
      return entries.map((entry) => ({ entry, config }))
    }),
  )
)
  .flat()
  .sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf())
---

<Layout class="max-w-3xl">
  <PageHead
    slot="head"
    title={`${author.data.name} (Author)`}
    description={author.data.bio || `Profile of ${author.data.name}.`}
    noindex
  />
  <Breadcrumbs
    items={[
      { href: '/authors', label: 'Authors', icon: 'lucide:users' },
      ...(isExec
        ? [
            { href: '/authors/exec', label: 'Exec', icon: 'lucide:sparkles' },
            { label: author.data.name, icon: 'lucide:user' },
          ]
        : [{ label: author.data.name, icon: 'lucide:user' }]),
    ]}
  />

  <section>
    <AuthorCard author={author} badges={badges} />
  </section>
  <section class="flex flex-col gap-y-4">
    <h2 class="text-2xl font-medium">Posts by {author.data.name}</h2>
    {
      authorEntries.length > 0 ? (
        <ul class="flex flex-col gap-4">
          {authorEntries
            .filter(({ entry }) => !entry.data.draft)
            .map(({ entry, config }) => (
              <li>
                <ContentCard entry={entry} config={config} />
              </li>
            ))}
        </ul>
      ) : (
        <p class="text-muted-foreground">
          No posts available from this author.
        </p>
      )
    }
  </section>
</Layout>
